# ============================================================
# Claude Code Web Service - 환경 설정
# ============================================================
# 이 파일을 .env로 복사한 후 실제 값을 채우세요:
#   cp .env.example .env
#   nano .env
# ============================================================

# [필수] Claude Code OAuth 토큰
# 로컬 PC에서 `claude setup-token` 실행 후 생성된 토큰
# 형식: sk-ant-oat01-...
CLAUDE_CODE_OAUTH_TOKEN=""

# [필수] OAuth 계정 정보
# 로컬 PC에서 아래 명령으로 추출:
#   cat ~/.claude.json | python3 -c "import json,sys; d=json.load(sys.stdin); print(json.dumps(d.get('oauthAccount'), indent=2))"
OAUTH_ACCOUNT_UUID=""
OAUTH_EMAIL=""
OAUTH_ORG_UUID=""

# [필수] 도메인
DOMAIN="claude.yourdomain.com"

# [필수] 검색 MCP API 키
BRAVE_API_KEY=""
EXA_API_KEY=""

# [선택] Supabase MCP
# 비워두면 Supabase MCP는 설정하지 않음
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# [선택] 자체 Mem0 서버
# 비워두면 mem0 MCP는 설정하지 않음
MEM0_API_URL=""
MEM0_API_KEY=""
MEM0_USER_ID="pm-default"

# ============================================================
# 아래는 기본값 — 변경 필요 없음
# ============================================================

# 서비스 유저명
SERVICE_USER="claudeweb"

# cloudcli 포트
CLOUDCLI_PORT="3001"

# Node.js 버전
NODE_VERSION="22"

# 자동 업데이트 시간 (KST, 24시간 형식)
UPDATE_HOUR_KST="9"
